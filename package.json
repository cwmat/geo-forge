{
  "name": "geo-forge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Client-side geospatial file viewer and converter powered by GDAL WebAssembly",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "postinstall": "node scripts/copy-gdal-assets.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.0",
    "@turf/bbox": "^7.0.0",
    "@turf/center": "^7.0.0",
    "@vis.gl/react-maplibre": "^8.1.0",
    "gdal3.js": "^2.8.0",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^4.0.0",
    "proj4": "^2.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.0",
    "@types/node": "^22.0.0",
    "@types/proj4": "^2.5.0",
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-top-level-await": "^1.4.0",
    "vite-plugin-wasm": "^3.4.0"
